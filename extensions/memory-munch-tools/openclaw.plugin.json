{
  "id": "memory-munch-tools",
  "kind": "memory",
  "name": "Memory-Munch Tools",
  "description": "Expose Memory-Munch deterministic retrieval tools to OpenClaw agents.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "configPath": { "type": "string" },
      "timeoutMs": { "type": "number", "minimum": 1000 },
      "autoInjectPromptContext": { "type": "boolean" },
      "exposeRawTools": { "type": "boolean" },
      "autoIndexWatch": { "type": "boolean" },
      "autoIndexWatchIntervalSec": { "type": "number", "minimum": 0.5 }
    }
  }
}
